# ══════════════════════════════════════════════════════════════
# Lucida Backend — Environment Variables
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your real values.
# NEVER commit .env to source control.
# ══════════════════════════════════════════════════════════════

# ── Turso Database ───────────────────────────────────────────
# Leave blank for local SQLite development.
# Set both TURSO_DATABASE_URL and TURSO_AUTH_TOKEN to use Turso.
# Get from: turso db show lucida --url
TURSO_DATABASE_URL=

# Get from: turso db tokens create lucida
TURSO_AUTH_TOKEN=

# ── Clerk Authentication ────────────────────────────────────
# Leave blank for local development auth bypass.
# Set in production, or when testing Clerk-backed auth locally.
# Get from: dashboard.clerk.com → your app → API Keys
# Secret key (backend only, starts with sk_test_ or sk_live_)
CLERK_SECRET_KEY=

# Publishable key (starts with pk_test_ or pk_live_)
CLERK_PUBLISHABLE_KEY=

# ── Application ─────────────────────────────────────────────
# Set to "production" for Railway deployment
# In production, CLERK_SECRET_KEY and at least one explicit CORS origin are required.
ENVIRONMENT=development

# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://lucidaanalytics.tech

# Directory where trained .joblib model files are stored
MODEL_ARTIFACTS_DIR=./model_artifacts
